# Bu dosya örnek/şablondur — gerçek değerleri .env.local içine yazın (o dosya gizlidir, yüklenmez).
# Vercel'de ise bu değişkenleri proje ayarlarındaki "Environment Variables" bölümüne ekleyin.

# Supabase (Proje Ayarları > API'den alınır)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxx

# Cloudinary (fotoğraf/video yükleme — sonraki adımda)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=xxxx
CLOUDINARY_API_KEY=xxxx
CLOUDINARY_API_SECRET=xxxx
